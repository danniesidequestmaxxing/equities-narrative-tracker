# Copy to .env and fill in. All values have safe stub defaults so the app
# imports and the test suite runs WITHOUT any of these set.
# Prefix is NT_ (Narrative Tracker).

# --- Database (Postgres in prod; SQLite default for local/tests) ---
# Prod example: postgresql+asyncpg://user:pass@host:5432/narrative_tracker
NT_DATABASE_URL=sqlite+aiosqlite:///./narrative_tracker.db

# --- Redis (optional in M0 — pre-check cache only; Postgres is authoritative) ---
# NT_REDIS_URL=redis://localhost:6379/0

# --- X / Twitter data feed (twitterapi.io) ---
# NT_TWITTERAPI_IO_KEY=

# --- Market data (Polygon / "Massive"); empty = recommend + scoring disabled ---
# NT_POLYGON_API_KEY=

# --- LLM (stance/extraction); empty = deterministic rule-based fallback ---
# NT_LLM_MODEL=anthropic/claude-opus-4-8
# NT_LLM_BUDGET_USD=100

# --- Telegram ---
# NT_TELEGRAM_BOT_TOKEN=
# NT_TELEGRAM_TRADING_CHAT_ID=
# NT_TELEGRAM_OPS_CHAT_ID=

# --- Observability ---
# NT_HEALTHCHECKS_URL=https://hc-ping.com/your-uuid

# --- Worker ---
# NT_ALERT_LATENCY_BUDGET_S=60

# --- Pulse: recurring investor briefing on Telegram (0 = disabled) ---
# NT_PULSE_INTERVAL_HOURS=8
